{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/check-alerts",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/check-alerts",
      "schedule": "0 20 * * *"
    }
  ]
}
